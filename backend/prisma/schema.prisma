generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InvoiceType {
  ONEHORIZON_FEE
  VENDOR_REBILL
  VENDOR_DIRECT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELED
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum Role {
  CLIENT_ADMIN
  CLIENT_USER
  PLATFORM_ADMIN
}

enum BillingMode {
  REBILL
  DIRECT_VENDOR
}

enum ServiceStatus {
  PENDING
  COMPLETED
  CANCELED
}

model User {
  id              String       @id @default(cuid())
  username        String       @unique
  email           String?      @unique
  password        String?
  name            String
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id])
  status          UserStatus   @default(INVITED)
  role            Role         @default(CLIENT_USER)
  phone           String?
  address         String?
  docType         String?
  docNumber       String?
  emailVerifiedAt DateTime?
  inviteTokens    InviteToken[]
  // GDPR fields
  consentedAt     DateTime?
  deletedAt       DateTime?
  consentLogs     ConsentLog[]
  gdprRequests    GdprRequest[]
  auditLogs       AuditLog[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model InviteToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tokenHash   String
  expiresAt   DateTime
  usedAt      DateTime?
  sentToEmail String?
  createdAt   DateTime @default(now())
}

model Client {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  users          User[]
  locations      Location[]
  invoices       Invoice[]
  documents      Document[]
  serviceRecords ServiceRecord[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Location {
  id             String          @id @default(cuid())
  clientId       String
  client         Client          @relation(fields: [clientId], references: [id])
  label          String
  address        String
  city           String?
  country        String?
  invoices       Invoice[]
  documents      Document[]
  serviceRecords ServiceRecord[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Vendor {
  id             String          @id @default(cuid())
  name           String
  email          String?
  invoices       Invoice[]
  serviceRecords ServiceRecord[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Invoice {
  id             String          @id @default(cuid())
  clientId       String
  client         Client          @relation(fields: [clientId], references: [id])
  locationId     String?
  location       Location?       @relation(fields: [locationId], references: [id])
  vendorId       String?
  vendor         Vendor?         @relation(fields: [vendorId], references: [id])

  type           InvoiceType
  status         InvoiceStatus   @default(ISSUED)
  number         String?
  issueDate      DateTime        @default(now())
  dueDate        DateTime?
  currency       String          @default("EUR")
  totalCents     Int

  payments       Payment[]
  documents      Document[]
  serviceRecords ServiceRecord[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  paidAt      DateTime @default(now())
  amountCents Int
  method      String?
  reference   String?
}

model Document {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
  invoiceId   String?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])

  name        String
  mimeType    String?
  sizeBytes   Int?
  storagePath String
  createdAt   DateTime  @default(now())
}

model ServiceRecord {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  locationId  String?
  location    Location?     @relation(fields: [locationId], references: [id])
  vendorId    String?
  vendor      Vendor?       @relation(fields: [vendorId], references: [id])
  title       String
  description String?
  serviceDate DateTime
  costCents   Int
  currency    String        @default("EUR")
  billingMode BillingMode   @default(REBILL)
  status      ServiceStatus @default(PENDING)
  invoiceId   String?
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ─── GDPR Models ─────────────────────────────────────────────────────────────

enum ConsentType {
  NECESSARY
  ANALYTICS
  MARKETING
}

enum GdprRequestType {
  ACCESS
  EXPORT
  DELETION
  RECTIFICATION
}

enum GdprRequestStatus {
  PENDING
  COMPLETED
  REJECTED
}

// Stores each consent event (banner acceptance, revocation, etc.)
model ConsentLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  type       ConsentType
  value      Boolean     // true = granted, false = revoked
  source     String?     // e.g. "cookie_banner", "settings"
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
}

// Tracks right-to-access / deletion / portability / rectification requests
model GdprRequest {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  type        GdprRequestType
  status      GdprRequestStatus  @default(PENDING)
  requestedAt DateTime           @default(now())
  resolvedAt  DateTime?
  notes       String?
}

// Audit log: who accessed personal data, when, from where
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // e.g. "GDPR_ACCESS", "GDPR_EXPORT", "GDPR_DELETE"
  endpoint   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}